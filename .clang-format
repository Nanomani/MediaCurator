BasedOnStyle: Microsoft
IndentWidth: 4
TabWidth: 4
UseTab: ForIndentation
ColumnLimit: 120
BreakBeforeBraces: Attach
AllowShortFunctionsOnASingleLine: Inline
AllowShortIfStatementsOnASingleLine: false
SortIncludes: CaseSensitive
IncludeBlocks: Regroup
IncludeCategories:
  # Own headers first
  - Regex: '^"'
    Priority: 1
  # Qt headers
  - Regex: '^<Q'
    Priority: 2
  # System / STL
  - Regex: '^<'
    Priority: 3
